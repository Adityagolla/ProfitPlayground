# Bearer token required by every private endpoint (Authorization: Bearer <token>)
API_TOKEN=dev-token

# Optional — if unset, the app runs in "memory only" mode (no DB writes, no persistence).
# Example: postgresql+psycopg://user:pass@localhost:5432/trading
DATABASE_URL=

# Network
HOST=127.0.0.1
PORT=8080

# Dev switch (auto-reload / verbose logs)
DEV=1

# Path to the C engine DLL (build with `make dll`). Unset => defaults to
# <repo>/bridge/libpipeline.dll. Set to empty to force the in-memory mock.
#PIPELINE_DLL=

# Finnhub API key (free: finnhub.io) — enables real stocks on the face-off
# roster. Without it only crypto (Binance, keyless) is offered.
#FINNHUB_API_KEY=
